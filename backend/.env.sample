# Adresse de l'hôte MySQL; 127.0.0.1 pour une instance locale
DB_HOST=127.0.0.1

# Port MySQL par défaut
DB_PORT=3306

# Nom d'utilisateur MySQL (par défaut: root en local)
DB_USER=root

# Mot de passe MySQL (laisser vide en local si aucun mot de passe)
DB_PASSWORD=

# Nom de la base de données à utiliser/créer
DB_NAME=blog_a_part

# Si true, le script de migration peut lancer un seed après l'application
# des migrations (utile pour remplir des données d'exemple).
RUN_SEED=false
