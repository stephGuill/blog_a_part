# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=5000

# ─── Base de données ──────────────────────────────────────────────────────────
# Développement local (WAMP / Docker local) :
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=blog_a_part
# SSL désactivé en local
DB_SSL=false

# Filess.io (hébergement MySQL gratuit) — remplacer les valeurs ci-dessous :
# Récupérer ces informations sur https://filess.io → votre base de données
# DB_HOST=xxxxxxxx.h.filess.io
# DB_PORT=3307
# DB_USER=blog_a_part_xxxxxxxx
# DB_PASSWORD=xxxxxxxxxxxxxxxx
# DB_NAME=blog_a_part_xxxxxxxx
# DB_SSL=true

# ─── JWT ──────────────────────────────────────────────────────────────────────
# En production : générer une clé longue et aléatoire (min 32 caractères)
# Exemple : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL du frontend autorisée par CORS (adapter en production)
FRONTEND_URL=http://localhost:5173

# ─── Migrations ───────────────────────────────────────────────────────────────
# Si true, le script de migration exécute le seed après les migrations
RUN_SEED=false
