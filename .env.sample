# ─── .env.sample (racine du projet) ───────────────────────────────────────────
# Variables d'environnement pour docker-compose.yml.
# Copier ce fichier en .env et remplir les valeurs avant de lancer Docker.
#
#   cp .env.sample .env
#
# ⚠️  Ne jamais committer le fichier .env (déjà dans .gitignore)

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer une clé unique :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL injectée dans le build Vite (visible dans le navigateur)
VITE_BACKEND_URL=http://localhost:5000
# URL autorisée par CORS côté backend
FRONTEND_URL=http://localhost:3000

# ==============================================================================
# MODE A — Filess.io (base de données distante, recommandé)
# ==============================================================================
# 1. Créer un compte sur https://filess.io
# 2. Créer une base de données MySQL
# 3. Copier les identifiants ci-dessous depuis votre tableau de bord Filess.io
# 4. Lancer : docker compose up --build

DB_HOST=xxxxxxxx.h.filess.io
DB_PORT=3307
DB_USER=blog_a_part_xxxxxxxx
DB_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DB_NAME=blog_a_part_xxxxxxxx
DB_SSL=true

# ==============================================================================
# MODE B — MySQL local dans Docker (sans connexion internet requise)
# ==============================================================================
# Décommenter ces lignes et commenter le bloc MODE A ci-dessus,
# puis lancer : docker compose --profile local up --build

# DB_HOST=db
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=rootpassword
# DB_NAME=blog_a_part
# DB_SSL=false
